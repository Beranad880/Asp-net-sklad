@page
@model WebApplicationASP1.Pages.Categories.CreateModel
@{
    ViewData["Title"] = "Nová kategorie";
}

<a asp-page="Index" class="back-link">Zpět na seznam</a>

<div class="page-header">
    <h1>Vytvořit kategorii</h1>
    <p>Vyplňte níže uvedené informace o nové kategorii.</p>
</div>

<div class="centered-container">
    <div class="form-card">
        <form method="post">
            <div class="form-group">
                <label asp-for="Category.Name">Název</label>
                <input asp-for="Category.Name" placeholder="Název kategorie" required />
            </div>
            <div class="form-group">
                <label asp-for="Category.Description">Popis</label>
                <textarea asp-for="Category.Description" rows="4" placeholder="Krátký popis kategorie..."></textarea>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-primary">Uložit kategorii</button>
                <a asp-page="Index" class="btn-danger">Zrušit</a>
            </div>
        </form>
    </div>
</div>
