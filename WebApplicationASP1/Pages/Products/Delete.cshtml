@page "{id}"
@model WebApplicationASP1.Pages.Products.DeleteModel
@{
    ViewData["Title"] = "Smazat produkt";
}

<a asp-page="Index" class="back-link">Zpět na seznam</a>

<div class="page-header">
    <h1>Smazat produkt</h1>
    <p>Tato akce je nevratná.</p>
</div>

<div class="centered-container">
    <div class="card">
        <h2 style="margin-bottom: 1.5rem; letter-spacing: -0.02em;">Opravdu chcete smazat tento produkt?</h2>

        <div class="delete-detail">
            <p class="delete-detail-label">Název</p>
            <p class="delete-detail-value">@Model.Product.Name</p>
            <p class="delete-detail-label">Cena</p>
            <p class="delete-detail-value">@Model.Product.Price.ToString("C")</p>
        </div>

        <form method="post">
            <input type="hidden" asp-for="Product.Id" />
            <div class="form-actions">
                <button type="submit" class="btn-danger">Potvrdit smazání</button>
                <a asp-page="Index" class="btn-primary">Zrušit</a>
            </div>
        </form>
    </div>
</div>
